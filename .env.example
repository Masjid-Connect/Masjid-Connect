# Django REST API base URL
EXPO_PUBLIC_API_URL=https://api.salafimasjid.app/api/v1

# Sentry — error tracking (get DSN from sentry.io)
EXPO_PUBLIC_SENTRY_DSN=

# Pinned mosque UUID — see DOCTRINE.md §6 (Single masjid). Hardcoding this
# removes a network roundtrip on cold start and the name-mismatch failure
# mode of the previous lookup-by-search approach. Production value below
# corresponds to the seed_data row.
EXPO_PUBLIC_MOSQUE_ID=98e7931b-8cf2-476e-99de-1daf4246c188
