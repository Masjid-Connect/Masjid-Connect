# =============================================================
# Production Environment Variables
# =============================================================
# Copy this file to .env.prod and fill in the real values:
#   cp .env.prod.example .env.prod
#
# NEVER commit .env.prod to git! It contains secrets.
# =============================================================

# Django
SECRET_KEY=replace-with-a-long-random-string-use-the-command-below
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"

ALLOWED_HOSTS=api.salafimasjid.app
DEBUG=False

# Database (must match docker-compose.prod.yml)
POSTGRES_DB=masjid_connect
POSTGRES_USER=mosque
POSTGRES_PASSWORD=replace-with-a-strong-password

# CORS — which websites/apps can call this API
CORS_ALLOWED_ORIGINS=https://salafimasjid.app

# Resend — email service for contact form
RESEND_API_KEY=replace-with-resend-api-key
CONTACT_TO_EMAIL=info@salafimasjid.app

# Stripe — donation payments
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
