# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*

# Database — PostgreSQL
DATABASE_URL=postgres://user:pass@localhost:5432/masjid_connect

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Apple Sign-In bundle ID (must match app.json bundleIdentifier)
APPLE_BUNDLE_ID=app.salafimasjid

# Google Sign-In client IDs (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Resend — email service for transactional emails
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@salafimasjid.app

# Frontend URL — used for password reset links
FRONTEND_URL=http://localhost:8081

# Sentry — error tracking (get DSN from sentry.io)
SENTRY_DSN_BACKEND=

# Cloudflare Turnstile — server-side validation for contact/donate forms
TURNSTILE_SECRET_KEY=

# Stripe — donation payments
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Email — Django SMTP backend (used for feedback admin notifications)
# If not set, feedback notifications go to stdout (console backend)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@salafimasjid.app
FEEDBACK_NOTIFY_EMAIL=info@salafimasjid.app

# CSRF — required when behind a reverse proxy (Cloudflare/Traefik)
CSRF_TRUSTED_ORIGINS=https://salafimasjid.app,https://api.salafimasjid.app

# CORS — additional Cloudflare Pages preview origins (comma-separated)
CORS_CF_PAGES_ORIGINS=

# Proxy — number of trusted proxies for accurate IP-based throttling
NUM_PROXIES=1

# PostgreSQL — used by docker-compose.prod.yml
POSTGRES_DB=masjid_connect
POSTGRES_USER=masjid
POSTGRES_PASSWORD=change-me-in-production

# Backups — offsite sync to S3-compatible storage (optional but recommended)
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
