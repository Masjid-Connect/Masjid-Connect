# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:pass@localhost:5432/masjid_connect

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Apple Sign-In bundle ID (must match app.json bundleIdentifier)
APPLE_BUNDLE_ID=app.salafimasjid

# Google Sign-In client IDs (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
