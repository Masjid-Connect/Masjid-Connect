# Django
DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=*

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:pass@localhost:5432/masjid_connect

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:8081

# CSRF — required for production (comma-separated)
CSRF_TRUSTED_ORIGINS=https://api.salafimasjid.app

# Apple Sign-In — bundle ID used to verify Apple identity tokens
# Must match your Apple Developer App ID / Services ID
APPLE_BUNDLE_ID=app.salafimasjid.mobile
