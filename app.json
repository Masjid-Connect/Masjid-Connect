{
  "expo": {
    "name": "The Salafi Masjid",
    "slug": "mosque-connect",
    "version": "1.0.0",
    "owner": "masjid-connect",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "salafimasjid",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID_HERE"
    },
    "splash": {
      "image": "./assets/images/Masjid_Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#F9F7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.salafimasjid",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "The Salafi Masjid app uses your location to calculate accurate prayer times and find nearby mosques.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F9F7F2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "app.salafimasjid",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "sounds": ["./assets/sounds/adhan.wav"]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "The Salafi Masjid app uses your location to calculate prayer times."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "SET_YOUR_EAS_PROJECT_ID_HERE"
      }
    }
  }
}
