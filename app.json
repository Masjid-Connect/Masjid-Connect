{
  "expo": {
    "name": "The Salafi Masjid",
    "slug": "masjid-app",
    "version": "1.0.0",
    "owner": "salafimasjid",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "salafimasjid",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#0F2D52",
    "description": "Prayer times, announcements, and events from The Salafi Masjid. Stay connected with your local mosque community.",
    "githubUrl": "https://github.com/Masjid-Connect/Masjid-Connect",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2c59ce1c-80b6-434a-9c9f-90a1fd1f415f"
    },
    "splash": {
      "image": "./assets/images/Masjid-Logo-App.png",
      "resizeMode": "contain",
      "backgroundColor": "#06101F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.salafimasjid",
      "icon": "./assets/images/icon.png",
      "splash": {
        "image": "./assets/images/Masjid-Logo-App.png",
        "resizeMode": "contain",
        "backgroundColor": "#06101F",
        "dark": {
          "image": "./assets/images/Masjid-Logo-App.png",
          "resizeMode": "contain",
          "backgroundColor": "#06101F"
        }
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "The Salafi Masjid app uses your location to calculate accurate prayer times and find nearby mosques.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#06101F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "app.salafimasjid",
      "splash": {
        "image": "./assets/images/Masjid-Logo-App.png",
        "resizeMode": "contain",
        "backgroundColor": "#06101F",
        "dark": {
          "image": "./assets/images/Masjid-Logo-App.png",
          "resizeMode": "contain",
          "backgroundColor": "#06101F"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "The Salafi Masjid",
      "shortName": "Salafi Masjid",
      "description": "Prayer times, announcements, and events from The Salafi Masjid.",
      "themeColor": "#0F2D52",
      "backgroundColor": "#F2EBD8"
    },
    "plugins": [
      "@sentry/react-native/expo",
      "expo-router",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/adhan.wav"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "The Salafi Masjid app uses your location to calculate prayer times."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "2c59ce1c-80b6-434a-9c9f-90a1fd1f415f"
      },
      "router": {}
    }
  }
}
