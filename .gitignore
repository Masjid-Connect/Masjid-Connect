# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# gstack (installed globally, not tracked in repo)
.claude/skills/gstack/

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# Google Play service account key
google-service-account.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# per-session scratch (research notes, sub-agent outputs, etc.)
# memory/ and projects/ are tracked; context/ is not
context/*
!context/.gitkeep
